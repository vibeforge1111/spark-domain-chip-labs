{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sparkswarm.ai/schemas/adaptive_creator_loop/creator-release-gate.schema.json",
  "title": "Adaptive Creator Loop Release Gate",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "requested_release",
    "verdict",
    "network_absorbable",
    "claim_boundary",
    "phase_status",
    "blocking_checks",
    "input_provenance",
    "next_actions"
  ],
  "properties": {
    "schema_version": {
      "const": "adaptive_creator_loop.creator_release_gate.v1"
    },
    "requested_release": {"type": "string", "minLength": 1},
    "verdict": {"enum": ["blocked", "review_ready"]},
    "network_absorbable": {"const": false},
    "claim_boundary": {
      "type": "string",
      "pattern": "does not approve network_absorbable"
    },
    "phase_status": {
      "type": "array",
      "minItems": 3,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "phase",
          "passed",
          "evidence_ref",
          "evidence_mode",
          "blocking_checks",
          "detail"
        ],
        "properties": {
          "phase": {"type": "string", "minLength": 1},
          "passed": {"type": "boolean"},
          "evidence_ref": {"type": ["string", "null"]},
          "evidence_mode": {"enum": ["missing", "saved", "fresh_run", "recomputed"]},
          "blocking_checks": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "detail": {"type": "object"}
        }
      },
      "allOf": [
        {"contains": {"properties": {"phase": {"const": "generated_multi_seed_validation"}}}},
        {"contains": {"properties": {"phase": {"const": "startup_yc_network_absorption_review"}}}},
        {"contains": {"properties": {"phase": {"const": "product_runtime_integration_review"}}}}
      ]
    },
    "blocking_checks": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "input_provenance": {
      "type": "array",
      "minItems": 4,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "path", "present", "sha256"],
        "properties": {
          "label": {"type": "string", "minLength": 1},
          "path": {"type": ["string", "null"]},
          "present": {"type": "boolean"},
          "sha256": {
            "type": ["string", "null"],
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"verdict": {"const": "blocked"}},
        "required": ["verdict"]
      },
      "then": {
        "properties": {
          "blocking_checks": {"minItems": 1}
        }
      }
    },
    {
      "if": {
        "properties": {"verdict": {"const": "review_ready"}},
        "required": ["verdict"]
      },
      "then": {
        "properties": {
          "blocking_checks": {"maxItems": 0},
          "phase_status": {
            "items": {
              "properties": {
                "passed": {"const": true},
                "blocking_checks": {"maxItems": 0}
              }
            }
          }
        }
      }
    }
  ]
}
