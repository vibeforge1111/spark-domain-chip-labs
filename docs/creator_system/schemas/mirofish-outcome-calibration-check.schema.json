{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sparkswarm.ai/schemas/adaptive_creator_loop/mirofish-outcome-calibration-check.schema.json",
  "title": "MiroFish Content Outcome Calibration Check",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "verdict",
    "calibration_supported",
    "network_absorbable",
    "claim_boundary",
    "row_count",
    "minimum_rows_required",
    "distinct_candidate_count",
    "checks",
    "blocking_checks",
    "next_actions"
  ],
  "properties": {
    "schema_version": {"const": "mirofish_content.outcome_calibration_check.v1"},
    "verdict": {"enum": ["supports_calibration", "inconclusive"]},
    "calibration_supported": {"type": "boolean"},
    "network_absorbable": {"const": false},
    "claim_boundary": {
      "const": "real content outcome calibration evidence; does not prove network absorption"
    },
    "row_count": {"type": "integer", "minimum": 0},
    "minimum_rows_required": {"type": "integer", "minimum": 2},
    "distinct_candidate_count": {"type": "integer", "minimum": 0},
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["check_id", "status", "message"],
        "properties": {
          "check_id": {"type": "string", "minLength": 1},
          "status": {"enum": ["pass", "fail"]},
          "message": {"type": "string", "minLength": 1}
        }
      }
    },
    "blocking_checks": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"verdict": {"const": "supports_calibration"}},
        "required": ["verdict"]
      },
      "then": {
        "properties": {
          "calibration_supported": {"const": true},
          "blocking_checks": {"maxItems": 0}
        }
      }
    },
    {
      "if": {
        "properties": {"verdict": {"const": "inconclusive"}},
        "required": ["verdict"]
      },
      "then": {
        "properties": {
          "calibration_supported": {"const": false},
          "blocking_checks": {"minItems": 1}
        }
      }
    }
  ]
}
