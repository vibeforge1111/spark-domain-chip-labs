{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sparkswarm.ai/schemas/adaptive_creator_loop/tool-operation-check.schema.json",
  "title": "Adaptive Creator Loop Tool Operation Check",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "operation_key",
    "verdict",
    "allowed",
    "claim_boundary",
    "checks",
    "blocking_checks",
    "rollback_note",
    "rollback_report",
    "next_actions"
  ],
  "properties": {
    "schema_version": {"const": "tool_operation.check_result.v1"},
    "operation_key": {
      "anyOf": [
        {"type": "string", "minLength": 1},
        {"type": "null"}
      ]
    },
    "verdict": {"enum": ["pass", "blocked"]},
    "allowed": {"type": "boolean"},
    "claim_boundary": {"const": "tool_operation local postcondition check only"},
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "message"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "status": {"enum": ["pass", "fail"]},
          "message": {"type": "string", "minLength": 1}
        }
      }
    },
    "blocking_checks": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "rollback_note": {"type": "string"},
    "rollback_report": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required",
        "provided",
        "note",
        "operation_key",
        "blocked_state_update",
        "blocking_checks",
        "result_verdict",
        "recommendation"
      ],
      "properties": {
        "required": {"type": "boolean"},
        "provided": {"type": "boolean"},
        "note": {"type": "string"},
        "operation_key": {
          "anyOf": [
            {"type": "string", "minLength": 1},
            {"type": "null"}
          ]
        },
        "blocked_state_update": {"type": "boolean"},
        "blocking_checks": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "result_verdict": {
          "anyOf": [
            {"type": "string"},
            {"type": "null"}
          ]
        },
        "recommendation": {"type": "string", "minLength": 1}
      }
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"verdict": {"const": "pass"}}
      },
      "then": {
        "properties": {
          "allowed": {"const": true},
          "blocking_checks": {"maxItems": 0},
          "rollback_report": {
            "properties": {
              "required": {"const": false},
              "blocked_state_update": {"const": false}
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"verdict": {"const": "blocked"}}
      },
      "then": {
        "properties": {
          "allowed": {"const": false},
          "blocking_checks": {"minItems": 1},
          "rollback_report": {
            "properties": {
              "required": {"const": true},
              "blocked_state_update": {"const": true}
            }
          }
        }
      }
    }
  ]
}
