{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sparkswarm.ai/schemas/adaptive_creator_loop/benchmark-pack-manifest.schema.json",
  "title": "Adaptive Creator Loop Benchmark Pack Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "benchmark_id",
    "benchmark_family",
    "target_capability",
    "case_lanes",
    "scoring",
    "promotion_rules"
  ],
  "properties": {
    "schema_version": {
      "const": "adaptive_creator_loop.benchmark_pack_manifest.v1"
    },
    "benchmark_id": {
      "type": "string",
      "minLength": 1
    },
    "benchmark_family": {
      "type": "string",
      "enum": [
        "fixed_case_rubric",
        "simulator",
        "tool_operation",
        "artifact_quality",
        "retrieval_memory",
        "adversarial",
        "longitudinal",
        "collective"
      ]
    },
    "target_capability": {
      "type": "string",
      "minLength": 1
    },
    "case_lanes": {
      "type": "object",
      "properties": {
        "development": {"type": "integer", "minimum": 0},
        "held_out": {"type": "integer", "minimum": 0},
        "adversarial": {"type": "integer", "minimum": 0},
        "regression": {"type": "integer", "minimum": 0}
      }
    },
    "scoring": {
      "type": "object",
      "required": ["primary_metric"],
      "properties": {
        "primary_metric": {"type": "string"},
        "component_metrics": {"type": "array", "items": {"type": "string"}},
        "judge_model": {"type": "string"},
        "calibration_examples_path": {"type": "string"},
        "score_report_schema": {"type": "string"}
      }
    },
    "anti_gaming_checks": {
      "type": "array",
      "items": {"type": "string"}
    },
    "promotion_rules": {
      "type": "object",
      "required": ["minimum_delta", "held_out_policy", "trap_policy"],
      "properties": {
        "minimum_delta": {"type": "number"},
        "held_out_policy": {"type": "string"},
        "trap_policy": {"type": "string"},
        "repeat_or_seed_policy": {"type": "string"}
      }
    },
    "claim_boundaries": {
      "type": "array",
      "items": {"type": "string"}
    }
  }
}
