{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sparkswarm.ai/schemas/adaptive_creator_loop/domain-chip-manifest.schema.json",
  "title": "Adaptive Creator Loop Domain Chip Manifest",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "domain"],
  "properties": {
    "schema_version": {"const": "adaptive_creator_loop.domain_chip_manifest.v1"},
    "chip_id": {"type": "string", "minLength": 1},
    "domain": {"type": "string", "minLength": 1},
    "domain_family": {"type": "string", "minLength": 1},
    "target_capability": {"type": "string", "minLength": 1},
    "hooks": {
      "type": "array",
      "items": {"enum": ["evaluate", "suggest", "packets", "watchtower"]}
    },
    "mutation_axes": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "mission_control_flow": {"type": "string"},
    "tool_operation_target": {"type": "string"},
    "invocation_triggers": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "simulator_config": {"type": "object"},
    "useful_to_spark": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "publication_boundary": {"const": "local_only"},
    "source_repo": {"type": "string", "minLength": 1},
    "source_files": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "role": {"type": "string", "minLength": 1}
  },
  "anyOf": [
    {
      "required": [
        "chip_id",
        "domain_family",
        "target_capability",
        "hooks",
        "mutation_axes",
        "publication_boundary"
      ],
      "properties": {
        "hooks": {"contains": {"const": "evaluate"}},
        "mutation_axes": {"minItems": 1}
      }
    },
    {
      "required": ["source_repo", "source_files", "role"],
      "properties": {"source_files": {"minItems": 1}}
    }
  ]
}
