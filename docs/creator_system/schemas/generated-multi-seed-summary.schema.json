{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sparkswarm.ai/schemas/adaptive_creator_loop/generated-multi-seed-summary.schema.json",
  "title": "Adaptive Creator Loop Generated Multi-Seed Summary",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "matrix",
    "verdict",
    "evidence_tier",
    "evidence_mode",
    "network_absorbable",
    "aggregate_hidden_failures",
    "passed_run_count",
    "blocked_run_count",
    "failed_seed_ids",
    "claim_boundary",
    "rows",
    "next_actions"
  ],
  "properties": {
    "schema_version": {
      "const": "adaptive_creator_loop.generated_multi_seed_validation.v1"
    },
    "matrix": {
      "type": "object",
      "required": [
        "domain_count",
        "variants_per_domain",
        "seeds",
        "target_run_count",
        "completed_run_count"
      ],
      "properties": {
        "domain_count": {"type": "integer", "minimum": 1},
        "variants_per_domain": {"type": "integer", "minimum": 1},
        "seeds": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "integer"}
        },
        "target_run_count": {"type": "integer", "minimum": 1},
        "completed_run_count": {"type": "integer", "minimum": 0}
      }
    },
    "verdict": {"enum": ["candidate_review", "blocked"]},
    "evidence_tier": {"enum": ["candidate_review", "blocked"]},
    "evidence_mode": {"const": "recomputed"},
    "network_absorbable": {"const": false},
    "aggregate_hidden_failures": {"const": false},
    "passed_run_count": {"type": "integer", "minimum": 0},
    "blocked_run_count": {"type": "integer", "minimum": 0},
    "failed_seed_ids": {
      "type": "array",
      "items": {"type": "string"}
    },
    "claim_boundary": {"type": "string", "minLength": 1},
    "rows": {
      "type": "array",
      "items": {"$ref": "#/$defs/generatedSeedRow"}
    },
    "next_actions": {
      "type": "array",
      "items": {"type": "string"}
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"verdict": {"const": "candidate_review"}},
        "required": ["verdict"]
      },
      "then": {
        "properties": {
          "failed_seed_ids": {"maxItems": 0},
          "blocked_run_count": {"const": 0}
        }
      }
    },
    {
      "if": {
        "properties": {"verdict": {"const": "blocked"}},
        "required": ["verdict"]
      },
      "then": {
        "properties": {
          "failed_seed_ids": {"minItems": 1},
          "blocked_run_count": {"minimum": 1}
        }
      }
    }
  ],
  "$defs": {
    "generatedSeedRow": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "seed_id",
        "base_domain_id",
        "domain_id",
        "domain_family",
        "variant_index",
        "seed",
        "run_dir",
        "verdict",
        "evidence_tier",
        "evidence_mode",
        "blocking_checks",
        "candidate_delta",
        "trap_regressions",
        "network_absorbable"
      ],
      "properties": {
        "seed_id": {"type": "string", "minLength": 1},
        "base_domain_id": {"type": "string", "minLength": 1},
        "domain_id": {"type": "string", "minLength": 1},
        "domain_family": {"type": "string", "minLength": 1},
        "variant_index": {"type": "integer", "minimum": 1},
        "seed": {"type": "integer"},
        "run_dir": {"type": "string", "minLength": 1},
        "verdict": {"enum": ["ready_for_swarm_packet", "blocked"]},
        "evidence_tier": {"enum": ["candidate_review", "blocked"]},
        "evidence_mode": {"const": "recomputed"},
        "blocking_checks": {
          "type": "array",
          "items": {"type": "string"}
        },
        "candidate_delta": {"type": "number"},
        "trap_regressions": {"type": "number"},
        "network_absorbable": {"const": false}
      }
    }
  }
}
