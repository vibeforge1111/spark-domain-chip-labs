{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sparkswarm.ai/schemas/adaptive_creator_loop/retrieval-memory-packet.schema.json",
  "title": "Adaptive Creator Loop Retrieval Memory Packet",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "packet_id", "entries"],
  "properties": {
    "schema_version": {
      "const": "adaptive_creator_loop.retrieval_memory_packet.v1"
    },
    "packet_id": {"type": "string", "minLength": 1},
    "entries": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "entry_id",
          "memory_lane",
          "source_kind",
          "summary",
          "source_refs",
          "freshness",
          "revalidated",
          "promotion_allowed",
          "contradicted_by",
          "provenance",
          "review"
        ],
        "properties": {
          "entry_id": {"type": "string", "minLength": 1},
          "memory_lane": {
            "enum": ["local_workspace", "private_user", "network_shareable"]
          },
          "source_kind": {"type": "string", "minLength": 1},
          "summary": {"type": "string", "minLength": 1},
          "source_refs": {
            "type": "array",
            "minItems": 1,
            "items": {"type": "string", "minLength": 1}
          },
          "freshness": {"enum": ["fresh", "stale"]},
          "revalidated": {"type": "boolean"},
          "promotion_allowed": {"type": "boolean"},
          "contradicted_by": {
            "type": "array",
            "items": {"type": "string"}
          },
          "provenance": {
            "type": "object",
            "additionalProperties": false,
            "required": ["source_path", "captured_at"],
            "properties": {
              "source_path": {"type": "string", "minLength": 1},
              "captured_at": {"type": "string", "minLength": 1}
            }
          },
          "review": {
            "type": "object",
            "additionalProperties": false,
            "required": ["approved", "reason"],
            "properties": {
              "approved": {"type": "boolean"},
              "reason": {"type": "string"}
            }
          }
        }
      }
    }
  }
}
