{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sparkswarm.ai/schemas/adaptive_creator_loop/swarm-contribution-packet.schema.json",
  "title": "Adaptive Creator Loop Swarm Contribution Packet",
  "type": "object",
  "required": [
    "schema_version",
    "packet_id",
    "creator_run_id",
    "source",
    "contribution",
    "evidence",
    "governance",
    "anti_drift"
  ],
  "properties": {
    "schema_version": {
      "const": "adaptive_creator_loop.swarm_contribution_packet.v1"
    },
    "packet_id": {"type": "string"},
    "creator_run_id": {"type": "string"},
    "source": {"type": "object"},
    "contribution": {"type": "object"},
    "evidence": {
      "type": "object",
      "required": [
        "tier",
        "baseline_score",
        "candidate_score",
        "mean_delta",
        "trap_regressions",
        "report_paths"
      ],
      "properties": {
        "tier": {"type": "string", "minLength": 1},
        "baseline_score": {"type": "number", "minimum": 0, "maximum": 1},
        "candidate_score": {"type": "number", "minimum": 0, "maximum": 1},
        "mean_delta": {"type": "number"},
        "trap_regressions": {"type": "integer", "minimum": 0},
        "fresh_agent_absorption_delta": {"type": "number"},
        "report_paths": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        }
      }
    },
    "governance": {
      "type": "object",
      "required": [
        "rollback_or_deprecation_rule",
        "privacy_boundary",
        "network_publication_allowed"
      ],
      "properties": {
        "rollback_or_deprecation_rule": {"type": "string"},
        "privacy_boundary": {"type": "string"},
        "network_publication_allowed": {"const": false}
      }
    },
    "anti_drift": {
      "type": "object",
      "required": ["known_limits"],
      "properties": {
        "known_limits": {"type": "array"}
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "governance": {
            "properties": {"network_publication_allowed": {"const": false}},
            "required": ["network_publication_allowed"]
          }
        }
      },
      "then": {
        "properties": {
          "anti_drift": {
            "properties": {
              "known_limits": {
                "contains": {"type": "string", "pattern": "network|publication|multi-seed|calibration"}
              }
            }
          }
        }
      }
    }
  ]
}
