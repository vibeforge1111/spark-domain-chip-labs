{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sparkswarm.ai/schemas/adaptive_creator_loop/creator-system-beta-check.schema.json",
  "title": "Adaptive Creator Loop Beta Readiness Check",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "verdict",
    "network_absorbable",
    "claim_boundary",
    "checks",
    "blocking_checks",
    "input_provenance",
    "next_actions"
  ],
  "properties": {
    "schema_version": {
      "const": "adaptive_creator_loop.creator_system_beta_check.v1"
    },
    "verdict": {"enum": ["pass", "blocked"]},
    "network_absorbable": {"const": false},
    "claim_boundary": {
      "type": "string",
      "pattern": "does not approve network absorption"
    },
    "checks": {
      "type": "array",
      "minItems": 6,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "status", "blocking_checks", "detail"],
        "properties": {
          "name": {"type": "string", "minLength": 1},
          "status": {"enum": ["pass", "fail"]},
          "blocking_checks": {
            "type": "array",
            "items": {"type": "string", "minLength": 1}
          },
          "detail": {"type": "object"}
        }
      },
      "allOf": [
        {"contains": {"properties": {"name": {"const": "creator_run_templates"}}}},
        {"contains": {"properties": {"name": {"const": "startup_yc_strict_smoke"}}}},
        {"contains": {"properties": {"name": {"const": "startup_yc_raw_evidence_shape"}}}},
        {"contains": {"properties": {"name": {"const": "startup_yc_network_absorption_boundary"}}}},
        {"contains": {"properties": {"name": {"const": "startup_yc_production_gate_workbench"}}}},
        {"contains": {"properties": {"name": {"const": "stronger_release_gate_boundary"}}}}
      ]
    },
    "blocking_checks": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "input_provenance": {
      "type": "array",
      "minItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["label", "path", "present", "sha256"],
        "properties": {
          "label": {"type": "string", "minLength": 1},
          "path": {"type": ["string", "null"]},
          "present": {"type": "boolean"},
          "sha256": {
            "type": ["string", "null"],
            "pattern": "^[a-f0-9]{64}$"
          }
        }
      }
    },
    "next_actions": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {"verdict": {"const": "pass"}},
        "required": ["verdict"]
      },
      "then": {
        "properties": {
          "blocking_checks": {"maxItems": 0},
          "checks": {
            "items": {
              "properties": {
                "status": {"const": "pass"},
                "blocking_checks": {"maxItems": 0}
              }
            }
          }
        }
      }
    },
    {
      "if": {
        "properties": {"verdict": {"const": "blocked"}},
        "required": ["verdict"]
      },
      "then": {
        "properties": {
          "blocking_checks": {"minItems": 1}
        }
      }
    }
  ]
}
