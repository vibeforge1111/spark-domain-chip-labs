{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sparkswarm.ai/schemas/adaptive_creator_loop/benchmark-report.schema.json",
  "title": "Adaptive Creator Loop Benchmark Report",
  "type": "object",
  "required": [
    "schema_version",
    "mean_score",
    "case_count",
    "provenance"
  ],
  "properties": {
    "schema_version": {
      "enum": [
        "adaptive_creator_loop.benchmark_report.v1",
        "adaptive_creator_loop.report.baseline.v1",
        "adaptive_creator_loop.report.candidate.v1"
      ]
    },
    "source_report": {"type": "string", "minLength": 1},
    "mode": {"type": "string", "minLength": 1},
    "mean_score": {"type": "number", "minimum": 0, "maximum": 1},
    "mean_delta": {"type": "number"},
    "pass_rate": {"type": "number", "minimum": 0, "maximum": 1},
    "case_count": {"type": "integer", "minimum": 1},
    "positive_cases": {"type": "integer", "minimum": 0},
    "negative_cases": {"type": "integer", "minimum": 0},
    "flat_cases": {"type": "integer", "minimum": 0},
    "trap_regressions": {"type": "integer", "minimum": 0},
    "decision": {"enum": ["keep", "revert"]},
    "lane_results": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": [
          "case_count",
          "baseline_mean",
          "candidate_mean",
          "mean_delta",
          "trap_regressions"
        ],
        "properties": {
          "case_count": {"type": "integer", "minimum": 1},
          "baseline_mean": {"type": "number", "minimum": 0, "maximum": 1},
          "candidate_mean": {"type": "number", "minimum": 0, "maximum": 1},
          "mean_delta": {"type": "number"},
          "trap_regressions": {"type": "integer", "minimum": 0}
        }
      }
    },
    "provenance": {
      "type": "object",
      "required": ["source", "input_hashes"],
      "properties": {
        "source": {"enum": ["creator_generator_v1", "startup_yc_external_v1"]},
        "computed_at": {"type": "string", "minLength": 1},
        "recomputed_from": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "input_hashes": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {"type": "string", "minLength": 64}
        }
      }
    }
  },
  "anyOf": [
    {
      "properties": {
        "schema_version": {"const": "adaptive_creator_loop.benchmark_report.v1"},
        "provenance": {
          "properties": {"source": {"const": "creator_generator_v1"}}
        }
      }
    },
    {
      "required": ["source_report", "mode", "pass_rate"],
      "properties": {
        "schema_version": {
          "enum": [
            "adaptive_creator_loop.report.baseline.v1",
            "adaptive_creator_loop.report.candidate.v1"
          ]
        },
        "provenance": {
          "properties": {"source": {"const": "startup_yc_external_v1"}}
        }
      }
    }
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "schema_version": {
            "const": "adaptive_creator_loop.benchmark_report.v1"
          }
        },
        "required": ["mean_delta"]
      },
      "then": {
        "required": ["decision", "trap_regressions", "lane_results"]
      }
    },
    {
      "if": {
        "properties": {"decision": {"const": "keep"}},
        "required": ["decision"]
      },
      "then": {
        "properties": {
          "mean_delta": {"exclusiveMinimum": 0},
          "trap_regressions": {"const": 0}
        }
      }
    }
  ],
  "additionalProperties": true
}
